#!/usr/bin/env python3
"""Sort and clean all piterm history files.

- Sorts entries chronologically by timestamp
- Removes project-setup commands that leaked into history
  (set -a, set +a, export *_DIR=, source .env, etc.)
- Removes corrupted multi-line entries (captured terminal output / tracebacks)
"""
import os
import re
import sys
from pathlib import Path

HISTORY_DIR = Path.home() / ".history"

REMOVE_EXACT = {
    "set -a",
    "set +a",
    "source .env",
    "unset OP_SERVICE_ACCOUNT_TOKEN",
}

REMOVE_PATTERNS = [
    re.compile(r"^export \w+_DIR="),
]

CORRUPTION_MARKERS = [
    "Traceback (most recent call last)",
    "ModuleNotFoundError:",
    "ImportError:",
    "SyntaxError:",
    "FileNotFoundError:",
    "PermissionError:",
    "OSError:",
    "KeyError:",
    "ValueError:",
    "TypeError:",
    "AttributeError:",
]

MAX_CONTINUATION_LINES = 5


def parse_entries(filepath: Path) -> list[tuple[int, list[str]]]:
    """Parse a zsh extended history file into (timestamp, raw_lines) entries."""
    entries: list[tuple[int, list[str]]] = []
    current_lines: list[str] = []
    current_ts = 0

    with open(filepath, "r", encoding="utf-8", errors="replace") as f:
        for raw_line in f:
            line = raw_line.rstrip("\n")
            if re.match(r"^: \d+:\d", line):
                if current_lines:
                    entries.append((current_ts, current_lines))
                current_lines = [line]
                m = re.match(r"^: (\d+):", line)
                current_ts = int(m.group(1)) if m else 0
            else:
                current_lines.append(line)

    if current_lines:
        entries.append((current_ts, current_lines))

    return entries


def extract_command(entry_lines: list[str]) -> str:
    m = re.match(r"^: \d+:\d+;(.*)$", entry_lines[0])
    if m:
        cmd = m.group(1)
        if cmd.endswith("\\"):
            cmd = cmd[:-1]
        return cmd.strip()
    return entry_lines[0]


def should_remove(entry_lines: list[str]) -> bool:
    cmd = extract_command(entry_lines)

    if cmd in REMOVE_EXACT:
        return True

    for pattern in REMOVE_PATTERNS:
        if pattern.match(cmd):
            return True

    continuations = entry_lines[1:]
    if continuations:
        joined = "\n".join(continuations)
        if any(marker in joined for marker in CORRUPTION_MARKERS):
            return True
        if len(continuations) > MAX_CONTINUATION_LINES:
            return True

    return False


def fix_file(filepath: Path) -> tuple[int, int, int]:
    entries = parse_entries(filepath)
    original = len(entries)

    entries = [(ts, lines) for ts, lines in entries if not should_remove(lines)]
    entries.sort(key=lambda e: e[0])

    with open(filepath, "w", encoding="utf-8") as f:
        for _, lines in entries:
            for line in lines:
                f.write(line + "\n")

    removed = original - len(entries)
    return original, len(entries), removed


def main() -> None:
    if not HISTORY_DIR.is_dir():
        print(f"No history directory found at {HISTORY_DIR}", file=sys.stderr)
        sys.exit(1)

    files = sorted(HISTORY_DIR.rglob("*.history"))
    for extra in [Path.home() / ".zsh_history", Path.home() / ".bash_history"]:
        if extra.is_file():
            files.append(extra)
    if not files:
        print("No history files found")
        sys.exit(0)

    print(f"Found {len(files)} history files under {HISTORY_DIR}")
    print()

    total_removed = 0
    for f in files:
        rel = f"~/{f.relative_to(Path.home())}"
        print(rel)
        original, final, removed = fix_file(f)
        if removed > 0:
            print(f"  sorted, removed {removed} entries ({original} -> {final})")
        else:
            print(f"  sorted ({final} entries)")
        total_removed += removed

    print()
    if total_removed > 0:
        print(f"Removed {total_removed} entries total.")
    print("Done. Restart project shells for changes to take effect.")


if __name__ == "__main__":
    main()
